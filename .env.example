# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/voicebridge?sslmode=require"

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your_jwt_secret_min_32_chars_change_in_production"
JWT_EXPIRES_IN="7d"

# ─── ElevenLabs ──────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# ─── Paystack ────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# ─── Email (SendGrid) ────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your_sendgrid_api_key
EMAIL_FROM=noreply@voicebridge.io
EMAIL_FROM_NAME=VoiceBridge

# ─── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# ─── Internal Webhook Secret (any random string) ──────────────────────────────
AGENT_WEBHOOK_SECRET=vb-super-secret-change-this

# ─── Backend URL (used for ElevenLabs tool webhook URLs) ──────────────────────
BACKEND_URL=http://localhost:5000

# ─── Google Places API (optional — fallback for unregistered businesses) ───────
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# ─── Claude Vision API (for image OCR in knowledge base) ──────────────────────
# Get from https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key
